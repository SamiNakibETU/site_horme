# Copier vers .env.local pour activer le contenu Sanity (sinon le site utilise data/projects.ts).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Token d’écriture (npm run seed:sanity) : à créer depuis le **projet** (pas org seule) :
# manage → projet sv32cak7 → API → Tokens → Editor ou Administrator
# Les tokens « organisation » + Media Library seuls donnent souvent 403 sur l’upload.
# Ne jamais committer .env.local
SANITY_API_WRITE_TOKEN=

# Lecture brouillons + Presentation / URL de preview (token « Viewer » avec Dataset read ou Editor)
SANITY_API_READ_TOKEN=

# Secret partagé avec le webhook Sanity (revalidation du cache Next après publication)
# Créer le même secret dans Sanity : Project → API → Webhooks → POST vers https://TON_SITE/api/revalidate
SANITY_REVALIDATE_SECRET=

# Optionnel : même ID pour le dossier studio/ (sanity dev)
# SANITY_STUDIO_PROJECT_ID=
# SANITY_STUDIO_DATASET=production

# Studio : URL du site Next pour l’iframe Presentation (ex. http://localhost:3000 ou https://cie-horme.vercel.app)
# SANITY_STUDIO_PREVIEW_URL=http://localhost:3000
